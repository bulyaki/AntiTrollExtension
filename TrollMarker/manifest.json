{
  "manifest_version": 3,
  "name": "FB Name Marker",
  "version": "1.1",
  "description": "Highlights specific Facebook names stored in a customizable list.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://*.facebook.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "FB Name Marker Settings"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://*.facebook.com/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ]
}
